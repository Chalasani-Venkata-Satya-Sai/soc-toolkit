# ============================================
# SOC Toolkit - API Key Configuration
# Copy this file to ".env" and fill in your keys.
# The toolkit will gracefully skip any source
# whose key is missing (no crashes).
# ============================================

# https://www.virustotal.com/gui/my-apikey
VT_API_KEY=

# https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# https://account.shodan.io/
SHODAN_API_KEY=

# Optional: Google Safe Browsing (URL reputation)
GSB_API_KEY=

# Cache TTL in seconds (default 6 hours) - avoids re-hitting APIs/rate limits
CACHE_TTL=21600

# HTTP request timeout in seconds
REQUEST_TIMEOUT=15
